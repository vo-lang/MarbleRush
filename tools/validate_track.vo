package main

import (
	"fmt"
	"os"
	"github.com/vo-lang/voplay/scene3d"
)

const defaultTrackPath = "assets/maps/scenic_track/track.json"

func main() {
	path := defaultTrackPath
	if len(os.Args) > 1 {
		path = os.Args[1]
	}
	asset, err := scene3d.LoadTrackAsset(path)
	if err != nil {
		fmt.Println("track validation failed: " + err.Error())
		os.Exit(1)
	}
	track, err := scene3d.NewTrack(asset)
	if err != nil {
		fmt.Println("track validation failed: " + err.Error())
		os.Exit(1)
	}
	issues := scene3d.CheckTrackTraversability(track, scene3d.TrackTraversabilityOptions{SampleStep: 1.0, MaxHeightDelta: 1.2, MaxSegmentLength: 12.0, MaxBoundaryDelta: 4.0})
	errors := 0
	warnings := 0
	for _, issue := range issues {
		if issue.Severity == scene3d.TrackIssueError {
			errors++
		} else {
			warnings++
		}
		printTrackIssue(issue)
	}
	if errors > 0 {
		fmt.Println("track validation failed: " + fmt.Sprint(errors) + " errors, " + fmt.Sprint(warnings) + " warnings")
		os.Exit(1)
	}
	fmt.Println("track validation passed: " + path + " length=" + fmt.Sprint(track.Length()) + "m warnings=" + fmt.Sprint(warnings))
}

func printTrackIssue(issue scene3d.TrackIssue) {
	severity := "WARN"
	if issue.Severity == scene3d.TrackIssueError {
		severity = "ERROR"
	}
	fmt.Println(severity + " " + issue.Code + " " + issue.Path + ": " + issue.Message)
}
